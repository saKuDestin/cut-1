# ============================================================
# 直播切片大师 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值后启动项目
# ============================================================

# ============================================================
# 1. 数据库（必填）
# ============================================================
# MySQL 连接字符串，格式：mysql://用户名:密码@主机:端口/数据库名
# 示例（本地）：mysql://root:123456@localhost:3306/livestream_clipper
# 示例（云数据库）：mysql://admin:password@rm-xxx.mysql.rds.aliyuncs.com:3306/livestream_clipper
DATABASE_URL=mysql://root:password@localhost:3306/livestream_clipper

# ============================================================
# 2. JWT 会话密钥（必填）
# ============================================================
# 用于签发和验证登录 Cookie，请设置一个随机字符串（至少32位）
# 可以用命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-string-at-least-32-chars

# ============================================================
# 3. DeepSeek API（必填 - AI 文案生成、对话）
# ============================================================
# 注册地址：https://platform.deepseek.com/
# 控制台 → API Keys → 创建新密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 4. Groq API（必填 - 语音转录 Whisper）
# ============================================================
# 注册地址：https://console.groq.com/
# 控制台 → API Keys → Create API Key
# 免费额度充足，速度极快
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 5. AWS S3 对象存储（必填 - 视频/文件存储）
# ============================================================
# 支持 AWS S3、阿里云 OSS、腾讯云 COS、Cloudflare R2、MinIO 等

# AWS S3（标准）：
# - 注册：https://aws.amazon.com/
# - IAM → 创建用户 → 附加 AmazonS3FullAccess 策略 → 创建访问密钥
S3_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
# S3_ENDPOINT=  # 留空表示使用 AWS S3（默认）

# 阿里云 OSS 示例（取消注释并填写）：
# S3_ACCESS_KEY_ID=your-aliyun-access-key-id
# S3_SECRET_ACCESS_KEY=your-aliyun-access-key-secret
# S3_BUCKET=your-oss-bucket-name
# S3_REGION=oss-cn-hangzhou
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 腾讯云 COS 示例：
# S3_ACCESS_KEY_ID=your-tencent-secret-id
# S3_SECRET_ACCESS_KEY=your-tencent-secret-key
# S3_BUCKET=your-cos-bucket-name
# S3_REGION=ap-guangzhou
# S3_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com

# Cloudflare R2 示例（免费额度大）：
# S3_ACCESS_KEY_ID=your-r2-access-key-id
# S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
# S3_BUCKET=your-r2-bucket-name
# S3_REGION=auto
# S3_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com

# ============================================================
# 6. 管理员账号（可选，首次部署时自动创建管理员）
# ============================================================
# 如果设置了这两个变量，服务器启动时会自动创建管理员账号
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your-admin-password

# ============================================================
# 7. 其他配置（可选）
# ============================================================
# 服务器端口，默认 3000
# PORT=3000

# 运行环境，生产环境设为 production
# NODE_ENV=production
